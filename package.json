{
  "name": "@vndv/pi-codegraph",
  "version": "0.1.1",
  "description": "CodeGraph tools for Pi Agent.",
  "license": "MIT",
  "type": "module",
  "author": "CodeGraph contributors",
  "homepage": "https://github.com/vndv/pi-codegraph#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vndv/pi-codegraph"
  },
  "bugs": {
    "url": "https://github.com/vndv/pi-codegraph/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "codegraph",
    "coding-agent",
    "code-intelligence"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./extensions/codegraph": "./extensions/codegraph.ts",
    "./extensions/codegraph.ts": "./extensions/codegraph.ts"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "ci": "npm run typecheck && npm test && npm pack --dry-run",
    "local-release": "changeset version && changeset publish",
    "publish-packages": "npm publish --access public --provenance",
    "prepack": "npm run typecheck && npm test",
    "prepublishOnly": "npm run ci",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "version-packages": "changeset version && npm install --package-lock-only --ignore-scripts"
  },
  "engines": {
    "node": ">=22.19.0 <25"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@earendil-works/pi-coding-agent": "^0.76.0",
    "@types/node": "^20.19.30",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
